{
    "hooks":  {
                  "BeforeTool":  [
                                     {
                                         "matcher":  "run_shell_command",
                                         "hooks":  [
                                                       {
                                                           "name":  "use-pnpm",
                                                           "type":  "command",
                                                           "command":  "node .gemini/hooks/pnpm-rewrite.cjs"
                                                       }
                                                   ]
                                     },
                                     {
                                         "matcher":  "ask_user",
                                         "hooks":  [
                                                       {
                                                           "name":  "notify-ask",
                                                           "type":  "command",
                                                           "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .gemini/hooks/notify-user.ps1 -Message \u0027I have a question for you!\u0027"
                                                       }
                                                   ]
                                     }
                                 ],
                  "AfterAgent":  [
                                     {
                                         "matcher":  "*",
                                         "hooks":  [
                                                       {
                                                           "name":  "notify-turn-end",
                                                           "type":  "command",
                                                           "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .gemini/hooks/notify-user.ps1 -Message \u0027Turn finished. Waiting for your prompt.\u0027"
                                                       }
                                                   ]
                                     }
                                 ],
                  "Notification":  [
                                       {
                                           "matcher":  "*",
                                           "hooks":  [
                                                         {
                                                             "name":  "notify-permission",
                                                             "type":  "command",
                                                             "command":  "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .gemini/hooks/notify-user.ps1 -Message \u0027Action required: Tool permission needed.\u0027"
                                                         }
                                                     ]
                                       }
                                   ]
              },
    "maxTurns":  60
}
